# Copy to backend/.env and fill production values.
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/autoinsight
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=10

# Optional server-side voice services.
# Browser speech recognition and browser voice output work without these,
# but uploading raw audio to /voice-assistant/ask and server MP3 output need OpenAI.
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_ADVISOR_MODEL=gpt-4o-mini

# Support email / password reset email.
SUPPORT_EMAIL=support@example.com
ADMIN_EMAILS=admin@example.com
FRONTEND_URL=http://localhost:3000
APP_ENV=development
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
RESEND_API_KEY=
SENDGRID_API_KEY=
RESET_TOKEN_EXPIRE_MINUTES=30

# Razorpay subscription billing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
